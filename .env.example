# ------------------------------------------------------------------
# OramShop — نمونه فایل تنظیمات محیطی
# این فایل را کپی کنید:  cp .env.example .env
# سپس مقادیر واقعی را جایگزین کنید. فایل .env هرگز commit نمی‌شود.
# ------------------------------------------------------------------

# --- Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# حالت توسعه سبک (ویندوز/بدون Redis و PostgreSQL): فقط این را True کنید
DEV_MODE=False

# آدرس‌های مخفی پنل‌ها — حتماً در production مقدار غیرقابل حدس بگذارید
# مثال: ADMIN_URL=panel-x7k2m9/   DASHBOARD_URL=manage-q3z8w1/
ADMIN_URL=admin/
DASHBOARD_URL=dashboard/
# دامنه‌های مجاز CSRF در production (با https)
CSRF_TRUSTED_ORIGINS=

# --- PostgreSQL ---
DB_NAME=oramshop
DB_USER=oramshop
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Email (SMTP) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@example.com
EMAIL_HOST_PASSWORD=change-me

# --- SMS.ir (ارسال OTP و وضعیت سفارش) ---
SMS_IR_API_KEY=change-me
SMS_IR_LINE_NUMBER=30007732
SMS_IR_TEMPLATE_ID=100000

# --- زرین‌پال ---
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# در production حتماً False شود
ZARINPAL_SANDBOX=True

# --- django-axes (قفل حساب بعد از تلاش‌های ناموفق) ---
DJANGO_AXES_FAILURE_LIMIT=5
DJANGO_AXES_COOLOFF_TIME=1

# --- فایل‌های استاتیک/مدیا روی S3/MinIO (اختیاری) ---
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=
# AWS_S3_REGION_NAME=

# Goftino live chat widget id (empty = widget disabled)
GOFTINO_ID=b5HHtR

# Static API key for the Telegram bot JSON API (empty = API disabled)
BOT_API_KEY=

# Set to False to run a REAL celery worker even in DEV_MODE (needs a broker):
#   CELERY_EAGER=False
#   CELERY_BROKER_URL=redis://localhost:6379/0
#   CELERY_RESULT_BACKEND=django-db   # results visible in the admin panel
# then run:  celery -A OramShop worker --beat -l info
