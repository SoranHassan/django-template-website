# OramShop celery worker + beat
# Place at: /etc/systemd/system/oramshop-celery.service
[Unit]
Description=OramShop celery worker and beat
After=network.target redis.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/srv/oramshop
EnvironmentFile=/srv/oramshop/.env
ExecStart=/srv/oramshop/.venv/bin/celery -A OramShop worker --beat -l info
Restart=always

[Install]
WantedBy=multi-user.target
